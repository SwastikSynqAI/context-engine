# ════════════════════════════════════════════════════════════════════
#  Context Engine — Environment Variables
#  Copy this file to .env and fill in your values.
#  Never commit .env to version control.
# ════════════════════════════════════════════════════════════════════

# ── Core (Required) ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...              # Get from console.anthropic.com
JWT_SECRET_KEY=                           # Generate: openssl rand -hex 32
ADMIN_EMAIL=admin@yourcompany.com
ADMIN_PASSWORD_HASH=                      # python3 -c "import bcrypt; print(bcrypt.hashpw(b'YourPassword', bcrypt.gensalt()).decode())"

# ── Database ──────────────────────────────────────────────────────
POSTGRES_PASSWORD=change-me-in-production
DATABASE_URL=postgresql+asyncpg://appuser:change-me-in-production@localhost:5432/context_engine

# ── Email / SMTP (Required for automation) ────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=you@yourcompany.com
SMTP_PASSWORD=                            # App password (not your login password)
HIRING_EMAIL=hiring@yourcompany.com       # From-address for all hiring emails

# ── HR Pipeline Thresholds (Optional — has defaults) ──────────────
HR_RESUME_SCORE_THRESHOLD=60             # Min resume score to trigger pre-screening
HR_SCREEN_SCORE_THRESHOLD=60             # Min screen score to advance
HR_TEST_PASS_THRESHOLD=60                # Min test score to pass
ADMIN_NOTIFY_EMAIL=                       # Notify on shortlists (defaults to ADMIN_EMAIL)

# ── Frontend ──────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3002        # Base URL for links in emails

# ── Google Integrations (Optional) ────────────────────────────────
GOOGLE_CREDENTIALS_JSON=                  # Path to OAuth2 credentials JSON
GMAIL_USER_EMAIL=                         # Gmail account to ingest
GOOGLE_SERVICE_ACCOUNT_JSON=             # Path to service account JSON
SHEETS_ID_1=                             # Spreadsheet IDs (add as many as needed)
GCAL_CALENDAR_ID=                        # Calendar ID for interview scheduling

# ── HubSpot (Optional) ────────────────────────────────────────────
HUBSPOT_API_KEY=

# ── Calendly Links (Optional) ─────────────────────────────────────
CALENDLY_DEFAULT_LINK=
CALENDLY_BD_LINK=
CALENDLY_OPS_LINK=

# ── HOD Email Routing (Optional) ──────────────────────────────────
HOD_BD_EMAIL=
HOD_OPS_EMAIL=
HOD_IT_EMAIL=
HOD_AI_EMAIL=
HOD_MARKETING_EMAIL=
HOD_FINANCE_EMAIL=
HOD_HR_EMAIL=

# ── Ingestion Schedule (Optional) ─────────────────────────────────
SCHEDULE_SHEETS=0 */6 * * *
SCHEDULE_GMAIL=0 */2 * * *
SCHEDULE_HUBSPOT=0 */4 * * *
SCHEDULE_DOCUMENTS=0 2 * * *
SCHEDULE_EVALUATOR=0 9 * * 1

# ── API ───────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# ── Compliance ────────────────────────────────────────────────────
PII_FIELDS=email,phone,mobile,personal_email,address
